# =============================================================
# Database
# =============================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=rubricheck
DB_USER=postgres
DB_PASSWORD=postgres
POSTGRES_HOST_PORT=5436

# =============================================================
# Backend
# =============================================================
BACKEND_HOST_PORT=8004
# When frontend and API use different domains, set CORS_ORIGIN to the frontend URL (e.g. https://demo.rubri-check.com)
CORS_ORIGIN=
BACKEND_CONTAINER_PORT=8001
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================
# Frontend
# =============================================================
FRONTEND_HOST_PORT=3005
FRONTEND_CONTAINER_PORT=3001

# =============================================================
# Dokploy
# =============================================================
DOKPLOY_DOMAIN=rubricheck.yourdomain.com

# =============================================================
# n8n Webhooks (paper upload grading)
# =============================================================
N8N_WEBHOOK_URL=http://localhost:5678/webhook/your-paper-webhook-id
N8N_EXAM_PROJECTS_WEBHOOK_URL=http://localhost:5678/webhook/your-exam-projects-webhook-id

# n8n auth (optional - if webhooks require encryption header)
N8N_KEY=
N8N_HEADER_NAME=n8nEncryptionKey

# =============================================================
# n8n container (if running n8n in same stack - optional)
# =============================================================
N8N_ENCRYPTION_KEY=
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_HOST_PORT=5683
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# =============================================================
# Moodle (quiz grading - backend)
# =============================================================
MOODLE_WEB_SERVICE_URL=http://localhost:8081/webservice/rest/server.php
WSTOKEN=your_moodle_webservice_token
N8N_MOODLE_WEB_HOOK=http://localhost:5678/webhook/your-moodle-quiz-webhook-id

# =============================================================
# Frontend build args (baked in at build time)
# =============================================================
VITE_API_URL=
VITE_COMPANY_NAME=RubriCheck
VITE_MOODLE_WEB_SERVICE_URL=http://localhost:8081/webservice/rest/server.php
VITE_WSTOKEN=your_moodle_webservice_token
