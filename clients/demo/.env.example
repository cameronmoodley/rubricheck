# PostgreSQL Database
DB_NAME=rubricheck
DB_USER=postgres
DB_PASSWORD=postgres
POSTGRES_HOST_PORT=5433

# Backend
BACKEND_HOST_PORT=8001
BACKEND_CONTAINER_PORT=8001
JWT_SECRET=your_jwt_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
FRONTEND_HOST_PORT=3001
FRONTEND_CONTAINER_PORT=3001

# Dokploy (set your domain for deployment)
DOKPLOY_DOMAIN=rubricheck.yourdomain.com

# n8n webhooks (required for paper upload grading)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/your-paper-webhook-id
N8N_EXAM_PROJECTS_WEBHOOK_URL=http://localhost:5678/webhook/your-exam-projects-webhook-id

# Optional: if API is on different subdomain, set for frontend build
# VITE_API_URL=https://api.rubricheck.yourdomain.com

# Optional: Moodle integration
# VITE_MOODLE_WEB_SERVICE_URL=
# VITE_WSTOKEN=
